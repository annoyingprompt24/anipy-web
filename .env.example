# Copy this to .env for local dev, or set these in Portainer's stack environment UI.

# Credentials for the web UI
ANIPY_USER=admin
ANIPY_PASS=changeme

# Absolute path on the host to your shared downloads directory
# This should match the volume your qBittorrent/Jellyfin containers use
DOWNLOAD_DIR=/mnt/media/downloads

# Port to expose the web UI on (default: 8088)
PORT=8088
